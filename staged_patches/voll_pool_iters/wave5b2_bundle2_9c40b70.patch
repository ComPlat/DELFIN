+    # Wave-5 O MULTIHAPTO_MM_ENFORCE: pull graph-declared M-M bonds toward
+    # crystallographic target.  Fires only on direct M-M edges; universal
+    # (non-metal classes have no M-M edges, single-metal classes likewise).
+    # Disable via DELFIN_MULTIHAPTO_MM_ENFORCE=0.
+    if _delfin_env_int("DELFIN_MULTIHAPTO_MM_ENFORCE", 1):
+        try:
+            for mi in metal_indices:
+                mi_atom = mol.GetAtomWithIdx(mi)
+                mi_sym = mi_atom.GetSymbol()
+                for nbr in mi_atom.GetNeighbors():
+                    ni = nbr.GetIdx()
+                    if ni <= mi:
+                        continue
+                    if nbr.GetSymbol() not in _METAL_SET:
+                        continue
+                    mm_key = frozenset({mi_sym, nbr.GetSymbol()})
+                    target = _METAL_METAL_BOND_LENGTHS.get(mm_key)
+                    if target is None:
+                        r1 = _COVALENT_RADII.get(mi_sym)
+                        r2 = _COVALENT_RADII.get(nbr.GetSymbol())
+                        if r1 is None or r2 is None:
+                            continue
+                        target = r1 + r2 + 0.4
+                    pos_i = _gp(mi)
+                    pos_j = _gp(ni)
+                    vec = pos_j - pos_i
+                    cur = float(np.linalg.norm(vec))
+                    if cur < 1e-6 or abs(cur - target) <= 0.20:
+                        continue
+                    unit = vec / cur
+                    shift = (target - cur) * 0.5
+                    _sp(mi, pos_i - unit * shift)
+                    _sp(ni, pos_j + unit * shift)
+        except Exception:
+            pass
+
