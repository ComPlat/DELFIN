+def _md_invariant_violated(
+    xyz_pre: str,
+    xyz_post: str,
+    mol_template,
+    tol_frac: float = 0.10,
+    tol_abs: float = 0.05,
+) -> bool:
+    """Strict M-D invariant rollback gate (Wave-5 P-MD-1).
+
+    Per ``feedback_md_invariant.md`` (Iter-15 doctrine): UFF must NOT shift
+    any defined metal-donor bond by more than ``max(tol_abs, tol_frac *
+    ideal)``.  Returns ``True`` (= rollback) if any template M-D pair
+    satisfies::
+
+        |d_post - d_pre| > max(tol_abs, tol_frac * ideal)
+
+    where ``ideal = _get_ml_bond_length(M_sym, D_sym)``.  Universal —
+    driven by template graph + global covalent-radius table; no SMILES /
+    refcode hardcodes (passes ``feedback_no_smiles_specific.md``).
+    """
+    if not RDKIT_AVAILABLE or mol_template is None:
+        return False
+    try:
+        lines_pre = [l for l in xyz_pre.strip().splitlines() if l.strip()]
+        lines_post = [l for l in xyz_post.strip().splitlines() if l.strip()]
+        n_atoms = mol_template.GetNumAtoms()
+        if len(lines_pre) != n_atoms or len(lines_post) != n_atoms:
+            return False
+        coords_pre: List[Tuple[float, float, float]] = []
+        coords_post: List[Tuple[float, float, float]] = []
+        for lp, lq in zip(lines_pre, lines_post):
+            p = lp.split()
+            q = lq.split()
+            if len(p) < 4 or len(q) < 4:
+                return False
+            coords_pre.append((float(p[1]), float(p[2]), float(p[3])))
+            coords_post.append((float(q[1]), float(q[2]), float(q[3])))
+        for atom in mol_template.GetAtoms():
+            if atom.GetSymbol() not in _METAL_SET:
+                continue
+            m_idx = atom.GetIdx()
+            m_sym = atom.GetSymbol()
+            for nbr in atom.GetNeighbors():
+                if nbr.GetAtomicNum() <= 1 or nbr.GetSymbol() in _METAL_SET:
+                    continue
+                d_idx = nbr.GetIdx()
+                d_sym = nbr.GetSymbol()
+                ideal = float(_get_ml_bond_length(m_sym, d_sym))
+                if ideal <= 0:
+                    continue
+                mx0, my0, mz0 = coords_pre[m_idx]
+                dx0, dy0, dz0 = coords_pre[d_idx]
+                d_pre = math.sqrt(
+                    (mx0 - dx0) ** 2 + (my0 - dy0) ** 2 + (mz0 - dz0) ** 2
+                )
+                mx1, my1, mz1 = coords_post[m_idx]
+                dx1, dy1, dz1 = coords_post[d_idx]
+                d_post = math.sqrt(
+                    (mx1 - dx1) ** 2 + (my1 - dy1) ** 2 + (mz1 - dz1) ** 2
+                )
+                tol = max(float(tol_abs), float(tol_frac) * ideal)
+                if abs(d_post - d_pre) > tol:
+                    return True
+        return False
+    except Exception:
+        return False
+
